{
  "manifest_version": 3,
  "name": "SnipKeep",
  "version": "1.0.0",
  "description": "Select text on any page and save it instantly to your Google Docs notes.",
  "key": "",
  "permissions": ["identity", "identity.email", "storage", "activeTab", "scripting", "notifications", "contextMenus", "clipboardWrite"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": ["https://docs.googleapis.com/*", "https://api.notion.com/*", "https://web.archive.org/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://docs.google.com/document/*"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SnipKeep",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "save-selection": {
      "suggested_key": {
        "mac": "Command+Shift+S",
        "default": "Ctrl+Shift+S"
      },
      "description": "Save selected text to notes"
    }
  },
  "oauth2": {
    "client_id": "923106050597-7ovnc2ci217jb5hqeca6sl2el56h0rtm.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}
